    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.38.0",
    "localforage": "^1.10.0",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "xlsx": "^0.18.5"
